# Copy this file to .deploy.env and fill in real values.
# Used by:
#   - setup_azure_once.sh
#   - deploy_update.sh

# Azure subscription + container apps
SUBSCRIPTION_ID="<azure-subscription-id>"
RG="stocksense-rg"
ENV_NAME="stocksense-env"
API_APP="stocksense-api"

# GHCR image publishing/pull
GH_USER="<github-username>"
GH_PAT="<github-classic-pat-with-package-read-write>"
API_IMAGE="ghcr.io/${GH_USER}/stocksense-api:latest"
PIPE_IMAGE="ghcr.io/${GH_USER}/stocksense-pipeline:latest"

# Core app secrets/config
DATABASE_URL="<neon-postgres-url>"
FRONTEND_ORIGINS="<frontend-origin-url>"
OPENAI_API_KEY="<openai-api-key>"

# Alerts email job secrets
SMTP_USER="<smtp-username>"
SMTP_PASS="<smtp-password-or-app-password>"
ALERT_FROM_EMAIL="<alerts-from-email>"

# News ingest provider keys
MARKETAUX_API_TOKEN="<marketaux-api-key>"
NEWSAPI_API_KEY="<newsapi-api-key>"
ALPHAVANTAGE_API_KEY="<alphavantage-api-key>"
GUARDIAN_API_KEY="<guardian-api-key>"
