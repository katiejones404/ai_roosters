# StockSense Environment Variables
# Copy this file to .env and fill in your values.
# Make sure .env is in your gitignore

# For Neon (production/staging):
#   Get this from the project dashboard at neon.tech (Katie owns the database, ask for credentials)
#   Format: postgresql://user:pass@host.neon.tech/dbname?sslmode=require

#Change value
DATABASE_URL=postgresql://stock_user:stock_pass@postgres:5432/stock_db

# ============================================================
# Authentication - Not Implemented Fully Yet
# ============================================================

# Secret key used to sign JWT login tokens.
# For production, generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# For local dev, the default in security.py is fine.

#Don't change value
SECRET_KEY=your-secret-key-change-this

# ============================================================
# FRONTEND - CORS
# ============================================================

# Comma-separated list of allowed frontend origins.
# Add the Render/Vercel/whatever else we end up using frontend URL here when deploying.

#Will be changed later
FRONTEND_ORIGINS=https://ai-roosters-webpage.vercel.app
# Frontend base URL used in password reset email links (change for deployment!!)
FRONTEND_URL=http://localhost:5173

# ============================================================
# PIPELINE (only needed in the pipeline container)
# ============================================================

# Set to 1 to force FinBERT to use CPU instead of GPU.
FINBERT_FORCE_CPU=1

HUGGINGFACE_HUB_TOKEN= 
HF_HOME=/cache/huggingface

OPENAI_API_KEY=

# Note: Kaggle credentials (kaggle.json) are mounted separately.
# See backend/Pipeline.Dockerfile for the volume mount path.

# ============================================================
# LOCAL DEV postgres container
# These are only used when running docker-compose locally.
# When pointing DATABASE_URL at Neon, these are unused.
# ============================================================
#Don't change
POSTGRES_DB=stock_db
POSTGRES_USER=stock_user
POSTGRES_PASSWORD=stock_pass

# ============================================================
# PRICE ALERT EMAIL (SMTP)
# Used to send email notifications when price alerts trigger.
# ============================================================
# SMTP_USER is the sender mailbox (recommended: dedicated app mailbox)
# Example sender: stocksense.alerts@gmail.com
# For Gmail, SMTP_PASS must be an App Password (not your normal login password).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=stocksense.alerts@gmail.com
SMTP_PASS=your_app_password_here(16-digit code with no spaces)
ALERT_FROM_EMAIL=stocksense.alerts@gmail.com

# Alert checker timing (seconds)
# Faster testing: set ALERT_CHECK_INTERVAL_SECONDS=30
ALERT_CHECK_INITIAL_DELAY_SECONDS=30
ALERT_CHECK_INTERVAL_SECONDS=300

# ============================================================
# SCHEDULER CONTROL
# ============================================================
# Startup one-time jobs (defaults are OFF for production-safe API startup)
RUN_ARTICLE_INGEST=0
RUN_PRICE_INGEST=0
RUN_ML_PIPELINES=0

# In-process background loops in API container.
# If you move scheduling to Azure Container Apps Jobs, set ENABLE_BACKGROUND_SCHEDULERS=0.
ENABLE_BACKGROUND_SCHEDULERS=1
ENABLE_ALERT_SCHEDULER=1
ENABLE_PRICE_INGEST_SCHEDULER=1
ENABLE_NEWS_INGEST_SCHEDULER=1
ENABLE_SENTIMENT_SCHEDULER=0

# Loop intervals (seconds)
PRICE_INGEST_INTERVAL_SECONDS=900
NEWS_INGEST_INTERVAL_SECONDS=7200
SENTIMENT_INTERVAL_SECONDS=21600

# ============================================================
# HISTORICAL HF NEWS INGEST (news_ingest.py)
# ============================================================
# Match Colab behavior: ingest only selected HF subsets instead of scanning the entire dataset.
NEWS_INGEST_FILTERED_MODE=1
NEWS_INGEST_HF_SUBSETS=yahoo_finance_felixdrinkall,reddit_finance_sp500,nyt_articles_2000_present,american_news_jonasbecker,cnbc_headlines,benzinga_6000stocks
NEWS_INGEST_STREAMING=0
NEWS_INGEST_PER_YEAR=1000
